{
  "schema": {
    "title": "Content Editor Lab",
    "description": "An exhaustive JSON Schema 2020-12 demo for stress-testing the editor UI.",
    "type": "object",
    "required": [
      "document",
      "content",
      "layout",
      "publishing",
      "collaboration",
      "styleGuide",
      "integrations",
      "analytics",
      "access",
      "compliance",
      "customFields",
      "featureFlags"
    ],
    "$defs": {
      "money": {
        "type": "object",
        "title": "Money",
        "required": [
          "currency",
          "amount"
        ],
        "properties": {
          "currency": {
            "type": "string",
            "title": "Currency",
            "enum": [
              "USD",
              "EUR",
              "GBP",
              "CAD"
            ],
            "default": "USD"
          },
          "amount": {
            "type": "number",
            "title": "Amount",
            "minimum": 0,
            "maximum": 100000,
            "multipleOf": 0.01
          }
        },
        "additionalProperties": false
      },
      "person": {
        "type": "object",
        "title": "Person",
        "required": [
          "name",
          "email"
        ],
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "email": {
            "type": "string",
            "title": "Email",
            "format": "email"
          },
          "role": {
            "type": "string",
            "title": "Role",
            "enum": [
              "editor",
              "designer",
              "marketer",
              "reviewer",
              "owner"
            ]
          },
          "phone": {
            "type": "string",
            "title": "Phone"
          }
        },
        "additionalProperties": false
      },
      "image": {
        "type": "object",
        "title": "Image",
        "required": [
          "url",
          "alt"
        ],
        "properties": {
          "url": {
            "type": "string",
            "title": "Image URL",
            "format": "uri"
          },
          "alt": {
            "type": "string",
            "title": "Alt text"
          },
          "caption": {
            "type": "string",
            "title": "Caption",
            "maxLength": 140
          },
          "focalPoint": {
            "type": "string",
            "title": "Focal point",
            "enum": [
              "center",
              "top",
              "bottom",
              "left",
              "right"
            ]
          }
        },
        "additionalProperties": false
      },
      "link": {
        "type": "object",
        "title": "Link",
        "required": [
          "href",
          "label"
        ],
        "properties": {
          "href": {
            "type": "string",
            "title": "Href",
            "format": "uri"
          },
          "label": {
            "type": "string",
            "title": "Label"
          },
          "external": {
            "type": "boolean",
            "title": "External",
            "default": false
          },
          "ariaLabel": {
            "type": "string",
            "title": "ARIA label"
          }
        },
        "additionalProperties": false
      },
      "seoBase": {
        "type": "object",
        "title": "SEO Base",
        "required": [
          "slug",
          "title",
          "description"
        ],
        "properties": {
          "slug": {
            "type": "string",
            "title": "Slug"
          },
          "title": {
            "type": "string",
            "title": "Meta title",
            "maxLength": 70
          },
          "description": {
            "type": "string",
            "title": "Meta description",
            "maxLength": 180
          },
          "canonicalUrl": {
            "type": "string",
            "title": "Canonical URL",
            "format": "uri"
          },
          "keywords": {
            "type": "array",
            "title": "Keywords",
            "minItems": 1,
            "maxItems": 8,
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      },
      "seoAdvanced": {
        "type": "object",
        "title": "SEO Advanced",
        "properties": {
          "robots": {
            "type": "string",
            "title": "Robots",
            "enum": [
              "index,follow",
              "noindex,follow",
              "noindex,nofollow"
            ],
            "default": "index,follow"
          },
          "openGraphTitle": {
            "type": "string",
            "title": "Open Graph title"
          },
          "openGraphDescription": {
            "type": "string",
            "title": "Open Graph description",
            "maxLength": 200
          },
          "openGraphImage": {
            "$ref": "#/$defs/image"
          }
        },
        "additionalProperties": false
      },
      "styleGuideCore": {
        "type": "object",
        "title": "Style Guide Core",
        "required": [
          "voice",
          "tone",
          "audience"
        ],
        "properties": {
          "voice": {
            "type": "string",
            "title": "Voice",
            "enum": [
              "playful",
              "direct",
              "technical",
              "luxury"
            ]
          },
          "tone": {
            "type": "string",
            "title": "Tone",
            "enum": [
              "confident",
              "friendly",
              "formal",
              "bold"
            ]
          },
          "audience": {
            "type": "string",
            "title": "Audience"
          },
          "emojiUsage": {
            "type": "boolean",
            "title": "Emoji usage",
            "default": false
          }
        },
        "additionalProperties": false
      },
      "styleGuideAdvanced": {
        "type": "object",
        "title": "Style Guide Advanced",
        "properties": {
          "readingLevel": {
            "type": "integer",
            "title": "Reading level",
            "minimum": 1,
            "maximum": 12
          },
          "lineLength": {
            "type": "number",
            "title": "Target line length",
            "minimum": 40,
            "maximum": 120
          },
          "useOxfordComma": {
            "type": "boolean",
            "title": "Use Oxford comma",
            "default": true
          }
        },
        "additionalProperties": false
      },
      "sso": {
        "type": "object",
        "title": "Single Sign-On",
        "required": [
          "provider"
        ],
        "properties": {
          "provider": {
            "type": "string",
            "title": "Provider",
            "enum": [
              "saml",
              "oauth",
              "passwordless"
            ]
          },
          "issuerUrl": {
            "type": "string",
            "title": "Issuer URL",
            "format": "uri"
          },
          "certificate": {
            "type": "string",
            "title": "Certificate",
            "writeOnly": true
          },
          "clientId": {
            "type": "string",
            "title": "Client ID"
          },
          "clientSecret": {
            "type": "string",
            "title": "Client secret",
            "writeOnly": true
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled",
            "default": true
          }
        },
        "dependentRequired": {
          "provider": [
            "issuerUrl",
            "certificate",
            "clientId",
            "clientSecret"
          ]
        },
        "additionalProperties": false
      },
      "heroBlock": {
        "type": "object",
        "title": "Hero block",
        "required": [
          "kind",
          "heading",
          "primaryCta"
        ],
        "properties": {
          "kind": {
            "const": "hero",
            "title": "Kind"
          },
          "heading": {
            "type": "string",
            "title": "Heading"
          },
          "subheading": {
            "type": "string",
            "title": "Subheading",
            "maxLength": 220
          },
          "align": {
            "type": "string",
            "title": "Alignment",
            "enum": [
              "left",
              "center",
              "right"
            ]
          },
          "backgroundColor": {
            "type": "string",
            "title": "Background color"
          },
          "primaryCta": {
            "$ref": "#/$defs/link"
          },
          "secondaryCta": {
            "$ref": "#/$defs/link"
          }
        },
        "additionalProperties": false
      },
      "richTextBlock": {
        "type": "object",
        "title": "Rich text block",
        "required": [
          "kind",
          "body"
        ],
        "properties": {
          "kind": {
            "const": "richText",
            "title": "Kind"
          },
          "body": {
            "type": "string",
            "title": "Body",
            "format": "textarea",
            "maxLength": 4000
          },
          "style": {
            "type": "string",
            "title": "Style",
            "enum": [
              "article",
              "note",
              "pullquote"
            ]
          },
          "footnotes": {
            "type": "array",
            "title": "Footnotes",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      },
      "galleryBlock": {
        "type": "object",
        "title": "Gallery block",
        "required": [
          "kind",
          "images"
        ],
        "properties": {
          "kind": {
            "const": "gallery",
            "title": "Kind"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "images": {
            "type": "array",
            "title": "Images",
            "minItems": 1,
            "maxItems": 6,
            "items": {
              "$ref": "#/$defs/image"
            }
          },
          "layout": {
            "type": "string",
            "title": "Layout",
            "enum": [
              "grid",
              "carousel",
              "masonry"
            ]
          }
        },
        "additionalProperties": false
      },
      "quoteBlock": {
        "type": "object",
        "title": "Quote block",
        "required": [
          "kind",
          "quote",
          "author"
        ],
        "properties": {
          "kind": {
            "const": "quote",
            "title": "Kind"
          },
          "quote": {
            "type": "string",
            "title": "Quote",
            "format": "textarea",
            "maxLength": 600
          },
          "author": {
            "type": "string",
            "title": "Author"
          },
          "role": {
            "type": "string",
            "title": "Role"
          },
          "sourceLink": {
            "$ref": "#/$defs/link"
          }
        },
        "additionalProperties": false
      },
      "statsBlock": {
        "type": "object",
        "title": "Stats block",
        "required": [
          "kind",
          "items"
        ],
        "properties": {
          "kind": {
            "const": "stats",
            "title": "Kind"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "items": {
            "type": "array",
            "title": "Items",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": [
                "label",
                "value"
              ],
              "properties": {
                "label": {
                  "type": "string",
                  "title": "Label"
                },
                "value": {
                  "type": "number",
                  "title": "Value",
                  "minimum": 0
                },
                "trend": {
                  "type": "string",
                  "title": "Trend",
                  "enum": [
                    "up",
                    "down",
                    "flat"
                  ]
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      },
      "calloutBlock": {
        "type": "object",
        "title": "Callout block",
        "required": [
          "kind",
          "message"
        ],
        "properties": {
          "kind": {
            "const": "callout",
            "title": "Kind"
          },
          "tone": {
            "type": "string",
            "title": "Tone",
            "enum": [
              "info",
              "success",
              "warning",
              "danger"
            ]
          },
          "message": {
            "type": "string",
            "title": "Message",
            "format": "textarea",
            "maxLength": 500
          },
          "action": {
            "$ref": "#/$defs/link"
          },
          "dismissible": {
            "type": "boolean",
            "title": "Dismissible",
            "default": true
          }
        },
        "additionalProperties": false
      },
      "emailIntegration": {
        "type": "object",
        "title": "Email integration",
        "required": [
          "enabled",
          "fromAddress"
        ],
        "properties": {
          "enabled": {
            "type": "boolean",
            "title": "Enabled",
            "default": true
          },
          "fromAddress": {
            "type": "string",
            "title": "From address",
            "format": "email"
          },
          "replyTo": {
            "type": "string",
            "title": "Reply-to",
            "format": "email"
          },
          "templates": {
            "type": "array",
            "title": "Templates",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      },
      "webhookIntegration": {
        "type": "object",
        "title": "Webhook integration",
        "required": [
          "enabled",
          "url",
          "events"
        ],
        "properties": {
          "enabled": {
            "type": "boolean",
            "title": "Enabled",
            "default": true
          },
          "url": {
            "type": "string",
            "title": "URL",
            "format": "uri"
          },
          "secret": {
            "type": "string",
            "title": "Secret",
            "writeOnly": true
          },
          "events": {
            "type": "array",
            "title": "Events",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "publish",
                "update",
                "archive",
                "delete"
              ]
            }
          }
        },
        "additionalProperties": false
      },
      "analyticsGoal": {
        "type": "object",
        "title": "Analytics goal",
        "required": [
          "name",
          "enabled"
        ],
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled",
            "default": true
          },
          "sampleRate": {
            "type": "number",
            "title": "Sample rate",
            "minimum": 0,
            "maximum": 1
          }
        },
        "additionalProperties": false
      }
    },
    "properties": {
      "document": {
        "type": "object",
        "title": "Document",
        "required": [
          "id",
          "title",
          "slug",
          "type",
          "status",
          "locale"
        ],
        "properties": {
          "id": {
            "type": "string",
            "title": "ID",
            "readOnly": true
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "slug": {
            "type": "string",
            "title": "Slug"
          },
          "type": {
            "type": "string",
            "title": "Type",
            "enum": [
              "article",
              "landing-page",
              "product-page",
              "guide"
            ]
          },
          "status": {
            "type": "string",
            "title": "Status",
            "enum": [
              "draft",
              "review",
              "scheduled",
              "published",
              "archived"
            ]
          },
          "locale": {
            "type": "string",
            "title": "Locale",
            "enum": [
              "en-US",
              "en-GB",
              "es-ES",
              "fr-FR"
            ]
          },
          "summary": {
            "type": "string",
            "title": "Summary",
            "maxLength": 240
          },
          "internalRevision": {
            "type": "integer",
            "title": "Internal revision",
            "readOnly": true
          },
          "isFeatured": {
            "type": "boolean",
            "title": "Featured",
            "default": false
          },
          "owner": {
            "$ref": "#/$defs/person"
          }
        },
        "additionalProperties": false
      },
      "content": {
        "type": "object",
        "title": "Content",
        "required": [
          "blocks"
        ],
        "properties": {
          "deck": {
            "type": "array",
            "title": "Deck",
            "minItems": 2,
            "maxItems": 4,
            "items": {
              "type": "string"
            }
          },
          "blocks": {
            "type": "array",
            "title": "Blocks",
            "minItems": 4,
            "items": {
              "oneOf": [
                {
                  "$ref": "#/$defs/heroBlock"
                },
                {
                  "$ref": "#/$defs/richTextBlock"
                },
                {
                  "$ref": "#/$defs/galleryBlock"
                },
                {
                  "$ref": "#/$defs/quoteBlock"
                },
                {
                  "$ref": "#/$defs/statsBlock"
                },
                {
                  "$ref": "#/$defs/calloutBlock"
                }
              ]
            }
          },
          "featureMatrix": {
            "type": "array",
            "title": "Feature matrix",
            "prefixItems": [
              {
                "type": "string",
                "title": "Primary feature"
              },
              {
                "type": "number",
                "title": "Priority",
                "minimum": 0,
                "maximum": 10
              },
              {
                "type": "boolean",
                "title": "Enabled"
              }
            ],
            "items": false
          },
          "supportingAssets": {
            "type": "array",
            "title": "Supporting assets",
            "items": {
              "$ref": "#/$defs/image"
            }
          }
        },
        "additionalProperties": false
      },
      "layout": {
        "type": "object",
        "title": "Layout",
        "required": [
          "columns",
          "gutter"
        ],
        "properties": {
          "columns": {
            "type": "integer",
            "title": "Columns",
            "minimum": 1,
            "maximum": 12
          },
          "gutter": {
            "type": "number",
            "title": "Gutter",
            "minimum": 0,
            "maximum": 64
          },
          "safeArea": {
            "type": "array",
            "title": "Safe area",
            "prefixItems": [
              {
                "type": "number",
                "title": "Top",
                "minimum": 0,
                "maximum": 128
              },
              {
                "type": "number",
                "title": "Right",
                "minimum": 0,
                "maximum": 128
              },
              {
                "type": "number",
                "title": "Bottom",
                "minimum": 0,
                "maximum": 128
              },
              {
                "type": "number",
                "title": "Left",
                "minimum": 0,
                "maximum": 128
              }
            ],
            "items": false
          },
          "breakpoints": {
            "type": "object",
            "title": "Breakpoints",
            "additionalProperties": {
              "type": "number"
            }
          },
          "density": {
            "type": "string",
            "title": "Density",
            "enum": [
              "comfortable",
              "compact",
              "spacious"
            ],
            "default": "comfortable"
          }
        },
        "additionalProperties": false
      },
      "publishing": {
        "type": "object",
        "title": "Publishing",
        "required": [
          "schedule",
          "channels"
        ],
        "properties": {
          "schedule": {
            "type": "object",
            "title": "Schedule",
            "required": [
              "mode"
            ],
            "properties": {
              "mode": {
                "type": "string",
                "title": "Mode",
                "enum": [
                  "immediate",
                  "scheduled"
                ]
              },
              "publishAt": {
                "type": "string",
                "title": "Publish at",
                "format": "date-time"
              },
              "timezone": {
                "type": "string",
                "title": "Timezone"
              },
              "notes": {
                "type": "string",
                "title": "Notes",
                "format": "textarea",
                "maxLength": 240
              }
            },
            "if": {
              "properties": {
                "mode": {
                  "const": "scheduled"
                }
              },
              "required": [
                "mode"
              ]
            },
            "then": {
              "required": [
                "publishAt",
                "timezone"
              ]
            },
            "else": {
              "required": [
                "notes"
              ]
            },
            "additionalProperties": false
          },
          "channels": {
            "type": "array",
            "title": "Channels",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "web",
                "mobile",
                "email",
                "social",
                "api"
              ]
            }
          },
          "priority": {
            "type": "integer",
            "title": "Priority",
            "minimum": 1,
            "maximum": 5
          },
          "expiresAt": {
            "type": "string",
            "title": "Expires at",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "collaboration": {
        "type": "object",
        "title": "Collaboration",
        "required": [
          "approvalRequired"
        ],
        "properties": {
          "approvalRequired": {
            "type": "boolean",
            "title": "Approval required",
            "default": true
          },
          "approvers": {
            "type": "array",
            "title": "Approvers",
            "items": {
              "$ref": "#/$defs/person"
            }
          },
          "primaryContact": {
            "title": "Primary contact",
            "anyOf": [
              {
                "type": "string",
                "title": "Email address",
                "format": "email"
              },
              {
                "type": "object",
                "title": "Contact card",
                "required": [
                  "name",
                  "email"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "title": "Name"
                  },
                  "email": {
                    "type": "string",
                    "title": "Email",
                    "format": "email"
                  },
                  "phone": {
                    "type": "string",
                    "title": "Phone"
                  }
                },
                "additionalProperties": false
              }
            ]
          },
          "reviewers": {
            "type": "array",
            "title": "Reviewers",
            "items": {
              "$ref": "#/$defs/person"
            }
          },
          "notifications": {
            "type": "object",
            "title": "Notifications",
            "additionalProperties": {
              "type": "boolean"
            }
          }
        },
        "dependentSchemas": {
          "approvalRequired": {
            "required": [
              "approvers"
            ]
          }
        },
        "additionalProperties": false
      },
      "styleGuide": {
        "title": "Style guide",
        "allOf": [
          {
            "$ref": "#/$defs/styleGuideCore"
          },
          {
            "$ref": "#/$defs/styleGuideAdvanced"
          }
        ]
      },
      "integrations": {
        "type": "object",
        "title": "Integrations",
        "required": [
          "email",
          "webhook",
          "sso"
        ],
        "properties": {
          "email": {
            "$ref": "#/$defs/emailIntegration"
          },
          "webhook": {
            "$ref": "#/$defs/webhookIntegration"
          },
          "sso": {
            "$ref": "#/$defs/sso"
          },
          "apiEndpoint": {
            "type": "string",
            "title": "API endpoint",
            "format": "uri"
          },
          "headers": {
            "type": "object",
            "title": "Headers",
            "additionalProperties": {
              "type": "string"
            }
          },
          "toggles": {
            "type": "object",
            "title": "Feature toggles",
            "additionalProperties": {
              "type": "boolean"
            }
          }
        },
        "additionalProperties": false
      },
      "analytics": {
        "type": "object",
        "title": "Analytics",
        "required": [
          "enabled",
          "provider"
        ],
        "properties": {
          "enabled": {
            "type": "boolean",
            "title": "Enabled",
            "default": true
          },
          "provider": {
            "type": "string",
            "title": "Provider",
            "enum": [
              "none",
              "ga4",
              "plausible",
              "mixpanel"
