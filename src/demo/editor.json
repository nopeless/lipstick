{
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Editor Testing Matrix",
    "description": "Low-level JSON Schema 2020-12 fixture for testing primitives, enums, arrays, objects, refs, composition, conditionals, maps, and secrets. Each top-level property is a feature bucket, not a product section.",
    "type": "object",
    "required": [
      "primitives",
      "enums",
      "arrays",
      "objects",
      "refs",
      "composition",
      "conditionals",
      "maps",
      "secrets"
    ],
    "$defs": {
      "person": {
        "type": "object",
        "title": "Person",
        "description": "Tests a reusable object ref with required fields and an enum.",
        "required": [
          "name",
          "email"
        ],
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "email": {
            "type": "string",
            "title": "Email",
            "format": "email"
          },
          "role": {
            "type": "string",
            "title": "Role",
            "enum": [
              "editor",
              "designer",
              "reviewer",
              "owner"
            ]
          },
          "phone": {
            "type": "string",
            "title": "Phone"
          }
        }
      },
      "money": {
        "type": "object",
        "title": "Money",
        "description": "Tests a reusable object ref with numeric bounds and defaults.",
        "required": [
          "currency",
          "amount"
        ],
        "properties": {
          "currency": {
            "type": "string",
            "title": "Currency",
            "enum": [
              "USD",
              "EUR",
              "GBP"
            ],
            "default": "USD"
          },
          "amount": {
            "type": "number",
            "title": "Amount",
            "minimum": 0,
            "maximum": 100000,
            "multipleOf": 0.01
          }
        }
      },
      "attachment": {
        "type": "object",
        "title": "Attachment",
        "description": "Tests nested media objects with URI, text, and optional metadata.",
        "required": [
          "url",
          "alt"
        ],
        "properties": {
          "url": {
            "type": "string",
            "title": "URL",
            "format": "uri"
          },
          "alt": {
            "type": "string",
            "title": "Alt text"
          },
          "kind": {
            "type": "string",
            "title": "Kind",
            "enum": [
              "image",
              "file"
            ]
          },
          "caption": {
            "type": "string",
            "title": "Caption",
            "maxLength": 140
          }
        }
      },
      "auditStamp": {
        "type": "object",
        "title": "Audit stamp",
        "description": "Tests allOf composition with required timestamp fields.",
        "required": [
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "createdAt": {
            "type": "string",
            "title": "Created at",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "title": "Updated at",
            "format": "date-time"
          }
        }
      },
      "fixedPrice": {
        "type": "object",
        "title": "Fixed price",
        "description": "Tests oneOf branches with a fixed pricing mode.",
        "required": [
          "mode",
          "price"
        ],
        "properties": {
          "mode": {
            "const": "fixed",
            "title": "Mode"
          },
          "price": {
            "$ref": "#/$defs/money"
          },
          "salePrice": {
            "$ref": "#/$defs/money"
          }
        }
      },
      "tieredPrice": {
        "type": "object",
        "title": "Tiered price",
        "description": "Tests oneOf branches with nested arrays of objects.",
        "required": [
          "mode",
          "tiers"
        ],
        "properties": {
          "mode": {
            "const": "tiered",
            "title": "Mode"
          },
          "tiers": {
            "type": "array",
            "title": "Tiers",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "minimum",
                "price"
              ],
              "properties": {
                "minimum": {
                  "type": "integer",
                  "title": "Minimum quantity",
                  "minimum": 1
                },
                "price": {
                  "$ref": "#/$defs/money"
                }
              }
            }
          }
        }
      }
    },
    "properties": {
      "primitives": {
        "type": "object",
        "title": "Primitives",
        "description": "Tests string, number, integer, boolean, and format validation.",
        "required": [
          "shortText",
          "slug",
          "email",
          "website",
          "launchAt",
          "score",
          "count",
          "enabled"
        ],
        "properties": {
          "shortText": {
            "title": "Short text",
            "anyOf": [
              {
                "type": "string",
                "title": "Text value",
                "minLength": 1,
                "maxLength": 24
              },
              {
                "type": "null",
                "title": "Null value"
              }
            ]
          },
          "slug": {
            "type": "string",
            "title": "Slug",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "email": {
            "type": "string",
            "title": "Email",
            "format": "email"
          },
          "website": {
            "type": "string",
            "title": "Website",
            "format": "uri"
          },
          "favoriteColor": {
            "type": "string",
            "title": "Favorite color",
            "format": "color"
          },
          "launchAt": {
            "type": "string",
            "title": "Launch at",
            "format": "date-time"
          },
          "score": {
            "title": "Score",
            "anyOf": [
              {
                "type": "number",
                "title": "Number value",
                "minimum": 0,
                "maximum": 100,
                "multipleOf": 0.5
              },
              {
                "type": "null",
                "title": "Null value"
              }
            ]
          },
          "count": {
            "type": "integer",
            "title": "Count",
            "minimum": 0,
            "maximum": 10
          },
          "enabled": {
            "title": "Enabled",
            "default": false,
            "anyOf": [
              {
                "type": "boolean",
                "title": "Boolean value"
              },
              {
                "type": "null",
                "title": "Null value"
              }
            ]
          },
          "nullableNote": {
            "title": "Nullable note",
            "anyOf": [
              {
                "type": "string",
                "title": "String value"
              },
              {
                "type": "null",
                "title": "Null value"
              }
            ]
          }
        }
      },
      "enums": {
        "type": "object",
        "title": "Enums",
        "description": "Tests enum rendering and const handling.",
        "required": [
          "status",
          "kind",
          "mode"
        ],
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "enum": [
              "draft",
              "review",
              "published"
            ]
          },
          "kind": {
            "const": "test-case",
            "title": "Kind"
          },
          "mode": {
            "type": "string",
            "title": "Mode",
            "enum": [
              "manual",
              "automatic"
            ]
          }
        }
      },
      "arrays": {
        "type": "object",
        "title": "Arrays",
        "description": "Tests plain arrays, tuple arrays, and arrays of refs.",
        "required": [
          "tags",
          "tuple",
          "attachments"
        ],
        "properties": {
          "tags": {
            "type": "array",
            "title": "Tags",
            "minItems": 1,
            "maxItems": 4,
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "tuple": {
            "type": "array",
            "title": "Tuple",
            "description": "Tests prefixItems tuple editing.",
            "prefixItems": [
              {
                "type": "string",
                "title": "Label"
              },
              {
                "type": "number",
                "title": "Weight"
              },
              {
                "type": "boolean",
                "title": "Enabled"
              }
            ],
            "minItems": 3,
            "maxItems": 3
          },
          "attachments": {
            "type": "array",
            "title": "Attachments",
            "minItems": 1,
            "maxItems": 2,
            "items": {
              "$ref": "#/$defs/attachment"
            }
          }
        }
      },
      "objects": {
        "type": "object",
        "title": "Objects",
        "description": "Tests closed objects and nested object shapes.",
        "required": [
          "closedRecord",
          "nestedRecord"
        ],
        "properties": {
          "closedRecord": {
            "type": "object",
            "title": "Closed record",
            "required": [
              "id",
              "label"
            ],
            "properties": {
              "id": {
                "type": "string",
                "title": "ID"
              },
              "label": {
                "type": "string",
                "title": "Label"
              },
              "active": {
                "type": "boolean",
                "title": "Active",
                "default": true
              }
            }
          },
          "nestedRecord": {
            "type": "object",
            "title": "Nested record",
            "required": [
              "owner",
              "attachment"
            ],
            "properties": {
              "owner": {
                "$ref": "#/$defs/person"
              },
              "attachment": {
                "$ref": "#/$defs/attachment"
              }
            }
          }
        }
      },
      "refs": {
        "type": "object",
        "title": "Refs",
        "description": "Tests direct $ref rendering for reusable definitions.",
        "required": [
          "personRef",
          "moneyRef",
          "attachmentRef"
        ],
        "properties": {
          "personRef": {
            "$ref": "#/$defs/person"
          },
          "moneyRef": {
            "$ref": "#/$defs/money"
          },
          "attachmentRef": {
            "$ref": "#/$defs/attachment"
          }
        }
      },
      "composition": {
        "type": "object",
        "title": "Composition",
        "description": "Tests allOf, anyOf, and oneOf in separate branches.",
        "required": [
          "identity",
          "contactChoice",
          "pricingStrategy"
        ],
        "properties": {
          "identity": {
            "title": "Identity",
            "allOf": [
              {
                "$ref": "#/$defs/person"
              },
              {
                "$ref": "#/$defs/auditStamp"
              }
            ]
          },
          "contactChoice": {
            "title": "Contact choice",
            "anyOf": [
              {
                "type": "string",
                "title": "Email string",
                "format": "email"
              },
              {
                "type": "object",
                "title": "Contact card",
                "required": [
                  "name",
                  "email"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "title": "Name"
                  },
                  "email": {
                    "type": "string",
                    "title": "Email",
                    "format": "email"
                  },
                  "phone": {
                    "type": "string",
                    "title": "Phone"
                  }
                }
              }
            ]
          },
          "pricingStrategy": {
            "title": "Pricing strategy",
            "oneOf": [
              {
                "$ref": "#/$defs/fixedPrice"
              },
              {
                "$ref": "#/$defs/tieredPrice"
              }
            ]
          }
        }
      },
      "conditionals": {
        "type": "object",
        "title": "Conditionals",
        "description": "Tests if/then/else, dependentRequired, and dependentSchemas.",
        "required": [
          "schedule",
          "approvalRules",
          "ssoConfig"
        ],
        "properties": {
          "schedule": {
            "type": "object",
            "title": "Schedule",
            "required": [
              "mode"
            ],
            "properties": {
              "mode": {
                "type": "string",
                "title": "Mode",
                "enum": [
                  "immediate",
                  "scheduled"
                ]
              },
              "publishAt": {
                "type": "string",
                "title": "Publish at",
                "format": "date-time"
              },
              "timezone": {
                "type": "string",
                "title": "Timezone"
              },
              "notes": {
                "type": "string",
                "title": "Notes",
                "maxLength": 240
              }
            },
            "if": {
              "properties": {
                "mode": {
                  "const": "scheduled"
                }
              },
              "required": [
                "mode"
              ]
            },
            "then": {
              "required": [
                "publishAt",
                "timezone"
              ]
            },
            "else": {
              "required": [
                "notes"
              ]
            }
          },
          "approvalRules": {
            "type": "object",
            "title": "Approval rules",
            "required": [
              "approvalRequired"
            ],
            "properties": {
              "approvalRequired": {
                "type": "boolean",
                "title": "Approval required",
                "default": true
              },
              "approvers": {
                "type": "array",
                "title": "Approvers",
                "items": {
                  "$ref": "#/$defs/person"
                }
              }
            },
            "dependentRequired": {
              "approvalRequired": [
                "approvers"
              ]
            }
          },
          "ssoConfig": {
            "type": "object",
            "title": "SSO config",
            "required": [
              "provider"
            ],
            "properties": {
              "provider": {
                "type": "string",
                "title": "Provider",
                "enum": [
                  "saml",
                  "oauth",
                  "passwordless"
                ]
              },
              "issuerUrl": {
                "type": "string",
                "title": "Issuer URL",
                "format": "uri"
              },
              "clientId": {
                "type": "string",
                "title": "Client ID"
              },
              "clientSecret": {
                "type": "string",
                "title": "Client secret",
                "writeOnly": true
              }
            },
            "dependentSchemas": {
              "provider": {
                "required": [
                  "issuerUrl",
                  "clientId",
                  "clientSecret"
                ]
              }
            }
          }
        }
      },
      "maps": {
        "type": "object",
        "title": "Maps",
        "description": "Tests open-ended objects and key-patterned maps.",
        "required": [
          "stringMap",
          "booleanMap",
          "patternMap"
        ],
        "properties": {
          "stringMap": {
            "type": "object",
            "title": "String map",
            "additionalProperties": {
              "type": "string"
            }
          },
          "booleanMap": {
            "type": "object",
            "title": "Boolean map",
            "additionalProperties": {
              "type": "boolean"
            }
          },
          "patternMap": {
            "type": "object",
            "title": "Pattern map",
            "description": "Tests patternProperties for controlled dynamic keys.",
            "patternProperties": {
              "^x-": {
                "type": "string"
              },
              "^flag-": {
                "type": "boolean"
              }
            }
          }
        }
      },
      "secrets": {
        "type": "object",
        "title": "Secrets",
        "description": "Tests readOnly, writeOnly, and defaulted fields together.",
        "required": [
          "readOnlyId",
          "apiSecret",
          "webhookSecret"
        ],
        "properties": {
          "readOnlyId": {
            "type": "string",
            "title": "Read-only ID",
            "readOnly": true
          },
          "apiSecret": {
            "type": "string",
            "title": "API secret",
            "writeOnly": true
          },
          "webhookSecret": {
            "type": "string",
            "title": "Webhook secret",
            "writeOnly": true
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled",
            "default": true
          }
        }
      }
    }
  },
  "value": {
