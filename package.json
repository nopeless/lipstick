{
  "name": "lipstick",
  "version": "0.1.0",
  "files": [
    "dist",
    "src/base-shared.css"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./define": {
      "types": "./dist/define.d.ts",
      "import": "./dist/define.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js"
    },
    "./base-shared.css": "./src/base-shared.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json",
    "build:demo": "vite build",
    "test": "tsc -p tsconfig.test.json && node --test .test-dist/tests/**/*.test.js",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "lit": "^3.3.2"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "oxlint": "^1.65.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vue": "3.5.0"
  }
}


